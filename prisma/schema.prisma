generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String?  // Google OAuth 矛聜卢矛職漏矛聻聬毛聤聰 毛鹿聞毛掳聙毛虏聢铆聵赂 矛聴聠矛聺聦
  name       String   @default("")
  role       String   @default("TEACHER") // ADMIN, TEACHER, DESK, PARENT, STUDENT
  phone      String?
  image      String?  // 铆聰聞毛隆聹铆聲聞 矛聺麓毛炉赂矛搂聙 (Google 铆聰聞毛隆聹铆聲聞)
  provider   String   @default("email") // email, google
  isApproved Boolean  @default(false) // 锚麓聙毛娄卢矛聻聬 矛聤鹿矛聺赂 矛聴卢毛露聙 (Google 锚掳聙矛聻聟 矛聜卢矛職漏矛聻聬)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  classrooms         Classroom[]
  parentStudents     ParentStudent[]
  counselingRequests CounselingRequest[]
  pushTokens         PushToken[]
  webPushSubscriptions WebPushSubscription[]
  studentProfile     Student?           // 铆聲聶矛聝聺 矛聴颅铆聲聽矛聺赂 锚虏陆矛職掳 Student矛聶聙 矛聴掳锚虏掳
  memos           Memo[]   @relation("memoAuthor")
}

model Student {
  id               String   @id @default(cuid())
  studentNumber    String   @unique
  name             String
  dateOfBirth      String?
  phone            String?
  parentPhone      String?  // 铆聲聶毛露聙毛陋篓 矛聴掳毛聺陆矛虏聵 (矛聲卤 毛隆聹锚路赂矛聺赂矛職漏)
  school           String?
  grade            String?
  status             String   @default("ACTIVE")
  withdrawalReason   String?  // 铆聡麓矛聸聬 矛聜卢矛聹聽
  withdrawalDate     DateTime? // 铆聡麓矛聸聬 矛聺录矛聻聬
  registrationDate   DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // 铆聲聶矛聝聺 毛隆聹锚路赂矛聺赂 矛聴掳锚虏掳 (矛聞聽铆聝聺矛聽聛 - 铆聲聶矛聝聺毛聫聞 矛聲卤矛聴聬 毛隆聹锚路赂矛聺赂 锚掳聙毛聤楼)
  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique

  parentStudents        ParentStudent[]
  enrollments           Enrollment[]
  grades                Grade[]
  attendanceRecords     AttendanceRecord[]
  assignmentSubmissions AssignmentSubmission[]
  counselingRequests    CounselingRequest[]
  memos              Memo[]
  payments              Payment[]
  dailyReports          DailyReport[]
}

model ParentStudent {
  id        String  @id @default(cuid())
  parent    User    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  parentId  String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  relation  String  @default("毛露聙毛陋篓")

  @@unique([parentId, studentId])
}

model Subject {
  id         String      @id @default(cuid())
  name       String      @unique
  code       String      @unique
  createdAt  DateTime    @default(now())
  classrooms Classroom[]
}

model Classroom {
  id          String   @id @default(cuid())
  name        String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  subjectId   String
  teacher     User     @relation(fields: [teacherId], references: [id])
  teacherId   String
  schedule    String?
  maxCapacity Int      @default(20)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments       Enrollment[]
  grades            Grade[]
  attendanceRecords AttendanceRecord[]
  assignments       Assignment[]
  dailyReports      DailyReport[]
  lectureVideos     LectureVideo[]
}

model Enrollment {
  id             String    @id @default(cuid())
  student        Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId      String
  classroom      Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  classroomId    String
  enrollmentDate DateTime  @default(now())
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())

  @@unique([studentId, classroomId])
}

model Grade {
  id          String    @id @default(cuid())
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  classroomId String
  testName    String
  score       Float
  maxScore    Float     @default(100)
  testDate    String
  remarks     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AttendanceRecord {
  id          String    @id @default(cuid())
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  classroomId String
  date        String
  status      String    @default("PRESENT")
  checkInTime String?
  remarks     String?
  createdAt   DateTime  @default(now())

  @@unique([studentId, classroomId, date])
}

model Assignment {
  id             String    @id @default(cuid())
  title          String
  description    String?
  classroom      Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  classroomId    String
  dueDate        String
  assignmentDate String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String
  status       String     @default("NOT_SUBMITTED")
  submittedAt  String?
  score        Float?
  feedback     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([assignmentId, studentId])
}

model CounselingRequest {
  id              String   @id @default(cuid())
  parent          User?    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  parentId        String?
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId       String
  title           String
  description     String?
  counselingType  String   @default("PHONE") // PHONE(矛聽聞铆聶聰矛聝聛毛聥麓), VISIT(毛掳漏毛卢赂矛聝聛毛聥麓)
  visitMessage    String?  // 毛掳漏毛卢赂矛聝聛毛聥麓 矛聥聹 矛聽聞毛聥卢矛聜卢铆聲颅
  preferredDate   String?
  status          String   @default("PENDING")
  adminNotes      String?
  sessionDate     String?
  sessionNotes    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  targetRole  String   @default("ALL")
  isActive    Boolean  @default(true)
  publishDate DateTime @default(now())
  expiryDate  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EntranceTest {
  id          String   @id @default(cuid())
  name        String
  school      String?
  grade       String?
  parentPhone String
  testDate    String
  testTime    String
  status      String   @default("SCHEDULED")
  notes       String?
  priorLevel      String?  // 矛聞聽铆聳聣矛聽聲毛聫聞
  testScore       String?  // 铆聟聦矛聤陇铆聤赂 矛聽聬矛聢聵
  counselingNotes String?  // 矛聝聛毛聥麓毛聜麓矛職漏
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id            String   @id @default(cuid())
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId     String
  yearMonth     String   // "2026-02" 铆聵聲矛聥聺
  tuitionFee    Int      @default(0) // 矛聢聵锚掳聲毛拢聦
  specialFee    Int      @default(0) // 铆聤鹿锚掳聲毛鹿聞
  otherFee      Int      @default(0) // 锚赂掳铆聝聙毛鹿聞矛職漏
  totalFee      Int      @default(0) // 矛麓聺矛聲隆 (矛聻聬毛聫聶 锚鲁聞矛聜掳)
  remarks       String?  // 毛鹿聞锚鲁聽
  status        String   @default("PENDING") // PENDING, INPUT_DONE, SENT, PAID
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// 芒聰聙芒聰聙 毛聧掳矛聺录毛娄卢 毛娄卢铆聫卢铆聤赂 (矛聞聽矛聝聺毛聥聵矛聺麓 铆聲聶矛聝聺毛鲁聞毛隆聹 毛搂陇矛聺录 矛聻聭矛聞卤) 芒聰聙芒聰聙
model DailyReport {
  id          String    @id @default(cuid())
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  classroomId String
  date        String    // "2026-02-26"
  content     String    // 矛聵陇毛聤聵矛聺聵 铆聲聶矛聤碌 毛聜麓矛職漏
  homework    String?   // 矛聢聶矛聽聹/锚鲁录矛聽聹 矛聲聢毛聜麓
  attitude    String?   // 铆聲聶矛聤碌 铆聝聹毛聫聞 (EXCELLENT, GOOD, NORMAL, NEEDS_IMPROVEMENT)
  specialNote String?   // 铆聤鹿矛聺麓矛聜卢铆聲颅
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([studentId, classroomId, date])
}

// 芒聰聙芒聰聙 锚掳聲矛聺聵 矛聵聛矛聝聛/毛搂聛铆聛卢 (毛掳聵毛鲁聞 锚掳聲矛聺聵 矛聻聬毛拢聦) 芒聰聙芒聰聙
model LectureVideo {
  id          String    @id @default(cuid())
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  classroomId String
  title       String
  description String?
  videoUrl    String    // YouTube, Vimeo 毛聯卤 矛聵聛矛聝聛 URL
  videoType   String    @default("YOUTUBE") // YOUTUBE, VIMEO, DIRECT, LINK
  duration    String?   // "45:00" 铆聵聲矛聥聺
  date        String    // 锚掳聲矛聺聵 毛聜聽矛搂聹
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 芒聰聙芒聰聙 锚掳聙矛聻聟矛聥聽矛虏颅 (铆聲聶毛露聙毛陋篓/铆聲聶矛聝聺 矛聲卤 毛聵聬毛聤聰 矛聶赂毛露聙 矛聥聽矛虏颅) 芒聰聙芒聰聙
model SignupRequest {
  id           String   @id @default(cuid())
  studentName  String   // 铆聲聶矛聝聺 矛聺麓毛娄聞
  school       String?  // 铆聲聶锚碌聬
  grade        String?  // 铆聲聶毛聟聞
  parentName   String?  // 铆聲聶毛露聙毛陋篓 矛聺麓毛娄聞
  parentPhone  String   // 铆聲聶毛露聙毛陋篓 矛聴掳毛聺陆矛虏聵
  studentPhone String?  // 铆聲聶矛聝聺 矛聴掳毛聺陆矛虏聵
  message      String?  // 矛聝聛毛聥麓 矛職聰矛虏颅矛聜卢铆聲颅 / 毛漏聰毛陋篓
  status       String   @default("PENDING") // PENDING(毛聦聙锚赂掳), APPROVED(矛聤鹿矛聺赂), REJECTED(锚卤掳矛聽聢)
  adminNotes   String?  // 锚麓聙毛娄卢矛聻聬 毛漏聰毛陋篓
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 芒聰聙芒聰聙 矛聴聟毛卢麓 矛職聰矛虏颅矛聜卢铆聲颅 (毛聦聙矛聥聹毛鲁麓毛聯聹) 芒聰聙芒聰聙
model TaskRequest {
  id          String   @id @default(cuid())
  title       String   // 矛職聰矛虏颅 毛聜麓矛職漏
  description String?  // 矛聝聛矛聞赂 矛聞陇毛陋聟
  createdBy   String   // 矛職聰矛虏颅矛聻聬 ID
  createdByName String @default("") // 矛職聰矛虏颅矛聻聬 矛聺麓毛娄聞
  targetRole  String   // TEACHER, DESK, ADMIN (毛聦聙矛聝聛 矛聴颅铆聲聽)
  assigneeId  String?  // 铆聤鹿矛聽聲 毛聥麓毛聥鹿矛聻聬 ID (矛聞聽铆聝聺)
  targetUserId  String?  // 矛職聰矛虏颅 毛聦聙矛聝聛 矛聜卢矛職漏矛聻聬 ID
  targetUserName String? // 矛職聰矛虏颅 毛聦聙矛聝聛 矛聜卢矛職漏矛聻聬 矛聺麓毛娄聞
  isCompleted Boolean  @default(false)
  completedBy String?  // 矛聶聞毛拢聦 矛虏聵毛娄卢铆聲聹 矛聜卢毛聻聦 ID
  completedAt DateTime? // 矛聶聞毛拢聦 矛聥聹锚掳聞
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 芒聰聙芒聰聙 铆聭赂矛聥聹 矛聲聦毛娄录 铆聠聽铆聛掳 (Expo Push Token) 芒聰聙芒聰聙
model PushToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String   @unique // Expo Push Token
  platform  String   @default("unknown") // ios, android
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 芒聙聰芒聙聰 矛聸鹿 铆聭赂矛聥聹 锚碌卢毛聫聟 (PWA 矛聸鹿 铆聭赂矛聥聹 矛聲聦毛娄录矛職漏) 芒聙聰芒聙聰
model WebPushSubscription {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// 芒聰聙芒聰聙 毛漏聰毛陋篓 (铆聲聶毛露聙毛陋篓/铆聲聶矛聝聺 芒聠聰 锚掳聲矛聜卢 矛聠聦铆聠碌) 芒聰聙芒聰聙
model Memo {
  id        String   @id @default(cuid())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  author    User     @relation("memoAuthor", fields: [authorId], references: [id])
  authorId  String
  content   String
  isFromParent Boolean @default(true) // true: 铆聲聶毛露聙毛陋篓/铆聲聶矛聝聺 矛聻聭矛聞卤, false: 锚掳聲矛聜卢 毛聥碌毛鲁聙
  parentMemoId String? // 毛聥碌毛鲁聙矛聺赂 锚虏陆矛職掳 矛聸聬毛鲁赂 毛漏聰毛陋篓 ID
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
  readAt    DateTime?
  updatedAt DateTime @updatedAt
}
